# ============================================
# 图书管理系统 — 环境变量配置模板
# ============================================
# 使用说明：
#   1. 复制此文件为 .env ：  cp .env.example .env
#   2. 填写你的实际配置值
#   3. 启动项目：  source .env && mvn spring-boot:run
#   4. .env 已被 .gitignore 忽略，不会提交到 Git
# ============================================

# 服务端口（默认 8080，可不填）
SERVER_PORT=8080

# MySQL 数据库配置
DB_URL=jdbc:mysql://localhost:3306/library_db?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&characterEncoding=utf-8
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# DeepSeek AI 配置（如不需要 AI 功能可留空）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat