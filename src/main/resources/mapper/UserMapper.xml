<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.library.mapper.UserMapper">

    <resultMap id="UserResultMap" type="com.example.library.entity.User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="role" column="role"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="findAdminByUsername" parameterType="String" resultMap="UserResultMap">
        SELECT id, username, password, 'admin' as role, create_time
        FROM dbo.uer
        WHERE username = #{username}
    </select>

    <select id="findReaderByUsername" parameterType="String" resultMap="UserResultMap">
        SELECT id, username, password, 'user' as role, create_time
        FROM dbo.t_user
        WHERE username = #{username}
    </select>

    <insert id="insertReader" parameterType="com.example.library.entity.User">
        INSERT INTO dbo.t_user (username, password, status, create_time, update_time)
        VALUES (#{username}, #{password}, 1, GETDATE(), GETDATE())
    </insert>

</mapper>
