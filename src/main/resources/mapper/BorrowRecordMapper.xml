<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.library.mapper.BorrowRecordMapper">

    <resultMap id="BorrowRecordResultMap" type="com.example.library.entity.BorrowRecord">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="bookId" column="book_id"/>
        <result property="borrowTime" column="borrow_time"/>
        <result property="dueTime" column="due_time"/>
        <result property="returnTime" column="return_time"/>
        <result property="status" column="status"/>
        <result property="renewCount" column="renew_count"/>
        <result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
        <!-- 关联查询出来的额外字段 -->
        <result property="userName" column="username"/>
        <result property="bookName" column="book_name"/>
    </resultMap>

    <select id="findAllWithDetails" resultMap="BorrowRecordResultMap">
        SELECT r.*, u.username, b.book_name
        FROM dbo.t_borrow_record r
        LEFT JOIN dbo.t_user u ON r.user_id = u.id
        LEFT JOIN dbo.t_book b ON r.book_id = b.id
        ORDER BY r.create_time DESC
    </select>

    <select id="findById" parameterType="java.lang.Long" resultMap="BorrowRecordResultMap">
        SELECT *
        FROM dbo.t_borrow_record
        WHERE id = #{id}
    </select>

    <update id="update" parameterType="com.example.library.entity.BorrowRecord">
        UPDATE dbo.t_borrow_record
        SET status = #{status},
            return_time = #{returnTime},
            remark = #{remark}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM dbo.t_borrow_record WHERE id = #{id}
    </delete>

</mapper>
